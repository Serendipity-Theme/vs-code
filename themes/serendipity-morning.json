  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#6d7296",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant"
      ],
      "settings": {
        "foreground": "#2f7aab"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.charcter.escape"
      ],
      "settings": {
        "foreground": "#e58678"
      }
    },
    {
      "scope": [
        "entity.name"
      ],
      "settings": {
        "foreground": "#e58678"
      }
    },
    {
      "scope": [
        "entity.name.section",
        "entity.name.tag",
        "entity.name.namespace",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#6288d8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#629aa5",
        "fontStyle": "italic"
      }
    },
    {
