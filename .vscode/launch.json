{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension (Morning)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "preLaunchTask": "serendipity: debug Morning",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--user-data-dir=${workspaceFolder}/.vscode-debug/user-data"
      ],
      "env": {
        "SERENDIPITY_DEBUG_THEME": "Serendipity Morning"
      },
      "settings": {
        "window.autoDetectColorScheme": false,
        "workbench.colorTheme": "Serendipity Morning"
      }
    },
    {
